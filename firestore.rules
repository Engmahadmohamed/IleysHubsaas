rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // Global Safety Net & Default Deny
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Core Helper Functions
    // ---------------------------------------------------------

    // Check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user's profile exists in the users collection
    function userProfileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Fetch authenticated user's profile document from /users/{userId}
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if the user is a Super Admin (UID-based or role-based fallback)
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'oCETlElgWMNrn8ZsSELl1Vsdr0B2' ||
        ('email' in request.auth.token && request.auth.token.email in ['mahadmohamed@gmail.com', 'mahadmohamedone@gmail.com', 'alimahad402@gmail.com']) ||
        (userProfileExists() && getUserData().role == 'superadmin')
      );
    }

    // Check if the user belongs to the specified organization, is active, and is authenticated
    function belongsToOrganization(orgId) {
      return isSignedIn() && 
             userProfileExists() && 
             getUserData().active == true &&
             getUserData().organizationId == orgId;
    }

    // Check if the user is an Admin of the organization
    function isOrganizationAdmin(orgId) {
      return belongsToOrganization(orgId) && 
             (getUserData().role == 'schooladmin' || getUserData().role == 'quranadmin');
    }

    // Check if the user is a Teacher belonging to the organization
    function isTeacher(orgId) {
      return belongsToOrganization(orgId) && getUserData().role == 'teacher';
    }

    // Safely get teacherId from user profile to prevent Map lookup errors if missing
    function getTeacherId() {
      return 'teacherId' in getUserData() ? getUserData().teacherId : '';
    }

    // Check if the user is a Staff member belonging to the organization
    function isStaff(orgId) {
      return belongsToOrganization(orgId) && getUserData().role == 'schoolstaff';
    }


    // ---------------------------------------------------------
    // Validation Blueprints (Data types, Enums, Ranges)
    // ---------------------------------------------------------

    function isValidUserProfile(data) {
      return data.uid is string &&
             data.email is string &&
             data.fullName is string &&
             data.role in ['superadmin', 'schooladmin', 'quranadmin', 'teacher', 'schoolstaff'] &&
             data.organizationId is string &&
             data.active is bool &&
             data.createdAt is string &&
             (!('teacherId' in data) || data.teacherId is string || data.teacherId == null) &&
             (!('staffDesignation' in data) || data.staffDesignation is string || data.staffDesignation == null);
    }

    function isValidOrganization(data) {
      return data.id is string &&
             data.name is string &&
             data.ownerName is string &&
             data.email is string &&
             data.type in ['school', 'quran', 'both'] &&
             data.status in ['active', 'suspended', 'expired'] &&
             data.monthlySubscription is number && data.monthlySubscription >= 0 &&
             data.createdAt is string &&
             (!('logoUrl' in data) || data.logoUrl is string || data.logoUrl == null);
    }

    function isValidStudent(data) {
      return data.id is string &&
             data.studentId is string &&
             data.fullName is string &&
             data.gender in ['male', 'female'] &&
             data.fee is number && data.fee >= 0 &&
             data.organizationId is string &&
             data.createdAt is string &&
             (!('profilePhoto' in data) || data.profilePhoto is string || data.profilePhoto == null) &&
             (!('studentPhone' in data) || data.studentPhone is string || data.studentPhone == null) &&
             (!('parentPhone' in data) || data.parentPhone is string || data.parentPhone == null) &&
             (!('address' in data) || data.address is string || data.address == null) &&
             (!('dob' in data) || data.dob is string || data.dob == null) &&
             (!('subjects' in data) || data.subjects is list || data.subjects == null);
    }

    function isValidTeacher(data) {
      return data.id is string &&
             data.fullName is string &&
             data.email is string &&
             data.salary is number && data.salary >= 0 &&
             data.organizationId is string &&
             data.createdAt is string &&
             (!('profilePhoto' in data) || data.profilePhoto is string || data.profilePhoto == null) &&
             (!('phone' in data) || data.phone is string || data.phone == null) &&
             (!('subjects' in data) || data.subjects is list || data.subjects == null) &&
             (!('rooms' in data) || data.rooms is list || data.rooms == null) &&
             (!('timeSchedule' in data) || data.timeSchedule is list || data.timeSchedule == null);
    }

    function isValidSubject(data) {
      return data.id is string &&
             data.name is string &&
             data.teacherId is string &&
             data.roomId is string &&
             data.organizationId is string &&
             (!('startTime' in data) || data.startTime is string || data.startTime == null) &&
             (!('endTime' in data) || data.endTime is string || data.endTime == null) &&
             (!('capacity' in data) || (data.capacity is number && data.capacity >= 0) || data.capacity == null);
    }

    function isValidAttendance(data) {
      return data.id is string &&
             data.date is string &&
             data.roomId is string &&
             data.subjectId is string &&
             data.teacherId is string &&
             data.organizationId is string &&
             data.records is list &&
             data.createdAt is string &&
             (!('sessionId' in data) || data.sessionId is string || data.sessionId == null);
    }

    function isValidFee(data) {
      return data.id is string &&
             data.studentId is string &&
             data.studentName is string &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['paid', 'unpaid', 'approved', 'cancelled'] &&
             data.invoiceNumber is string &&
             data.month is string &&
             data.organizationId is string &&
             (!('paidAt' in data) || data.paidAt is string || data.paidAt == null);
    }

    function isValidSalary(data) {
      return data.id is string &&
             data.teacherId is string &&
             data.teacherName is string &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'paid'] &&
             data.month is string &&
             data.organizationId is string &&
             (!('paidAt' in data) || data.paidAt is string || data.paidAt == null);
    }

    // Match exact AppContext schema
    function isValidExam(data) {
      return data.id is string &&
             data.title is string &&
             data.type in ['school', 'class'] &&
             data.createdAt is string &&
             data.published is bool &&
             data.organizationId is string &&
             (!('subjectId' in data) || data.subjectId is string || data.subjectId == null) &&
             (!('targetClass' in data) || data.targetClass is string || data.targetClass == null);
    }

    function isValidExamResult(data) {
      return data.id is string &&
             data.examId is string &&
             data.examTitle is string &&
             data.organizationId is string &&
             data.results is list &&
             data.average is number &&
             data.published is bool &&
             data.createdAt is string &&
             (!('subjectId' in data) || data.subjectId is string || data.subjectId == null);
    }

    function isValidClassSession(data) {
      return data.id is string &&
             data.classCode is string &&
             data.subjectId is string &&
             data.teacherId is string &&
             data.roomId is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.days is list &&
             data.capacity is number && data.capacity >= 0 &&
             data.status in ['active', 'completed'] &&
             data.studentsCount is number &&
             data.organizationId is string &&
             data.createdAt is string;
    }


    // ---------------------------------------------------------
    // Collection Group Security (Zero-Trust Point Queries)
    // ---------------------------------------------------------

    // Students collection group query security
    match /{path=**}/students/{studentId} {
      // Allow Super Admin, or allow unauthenticated point search (limit 1) used by public portal
      allow list: if isSuperAdmin() || 
                     (request.auth == null && request.query.limit <= 1);
      allow get: if isSuperAdmin() || request.auth != null || (request.auth == null);
      allow write: if isSuperAdmin();
    }

    // Class Sessions collection group query security
    match /{path=**}/class_sessions/{sessionId} {
      allow list, get: if isSuperAdmin() || (request.auth != null && getUserData().role == 'teacher');
      allow write: if isSuperAdmin();
    }


    // ---------------------------------------------------------
    // 1. Users Collection
    // ---------------------------------------------------------
    match /users/{userId} {
      // Anyone logged in can read user profiles (staff directory & lookups)
      // Unauthenticated users can read if the user document is active (for login/auto-registration fallback)
      allow read: if isSignedIn() || (resource != null && resource.data.active == true);

      // Only Super Admin, the user themselves (initial signup), or organization admins creating staff
      allow create: if isSuperAdmin() || 
                       (isSignedIn() && request.auth.uid == userId && isValidUserProfile(request.resource.data)) ||
                       (isOrganizationAdmin(request.resource.data.organizationId) && 
                        isValidUserProfile(request.resource.data) && 
                        request.resource.data.role in ['schooladmin', 'quranadmin', 'teacher', 'schoolstaff']);

      // Users can only update their own non-auth properties; Super Admin or Org Admins can manage staff profiles
      allow update: if (isSuperAdmin() && isValidUserProfile(request.resource.data)) || 
                      (isSignedIn() && request.auth.uid == userId && 
                       isValidUserProfile(request.resource.data) && 
                       request.resource.data.role == resource.data.role && 
                       request.resource.data.organizationId == resource.data.organizationId &&
                       request.resource.data.active == resource.data.active) ||
                      (isOrganizationAdmin(resource.data.organizationId) && 
                       isValidUserProfile(request.resource.data) && 
                       request.resource.data.organizationId == resource.data.organizationId &&
                       request.resource.data.role in ['schooladmin', 'quranadmin', 'teacher', 'schoolstaff'] &&
                       resource.data.role != 'superadmin');

      // Only Super Admin can hard delete users
      allow delete: if isSuperAdmin();
    }


    // ---------------------------------------------------------
    // 2. Multi-Tenant Scoped Collections
    // ---------------------------------------------------------
    match /organizations/{organizationId} {
      
      // Tenant Isolation: Only Super Admin or members of the organization can read settings
      allow get: if true;
      allow list: if isSuperAdmin() || belongsToOrganization(organizationId);
      allow write: if isSuperAdmin() && (request.resource == null || isValidOrganization(request.resource.data));

      // ---- STUDENTS ----
      match /students/{studentId} {
        // Staff members of the same organization can read student files
        allow read: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || isStaff(organizationId);
        
        // Admins and staff can create and update student records
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) && 
                         isValidStudent(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;
                         
        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) && 
                         isValidStudent(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;
        
        // Permanent deletions are restricted to Super Admin or Organization Admin
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- TEACHERS ----
      match /teachers/{teacherId} {
        // Staff members of the organization can read teacher profiles
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        
        // Only Admins can create or update teacher profiles
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId)) && 
                         isValidTeacher(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId)) && 
                         isValidTeacher(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;
        
        // Permanent deletions are restricted to Super Admin or Organization Admin
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- SUBJECTS ----
      match /subjects/{subjectId} {
        // Admins and staff read all; Teachers read only assigned subjects
        allow read: if isSuperAdmin() || 
                       isOrganizationAdmin(organizationId) || 
                       isStaff(organizationId) ||
                       (isTeacher(organizationId) && (resource.data.teacherId == getTeacherId() || resource.data.teacherId == request.auth.uid || getTeacherId() == '')) ||
                       (request.auth == null); // Allow ResultPortal.tsx to map subjectId to subjectName
        
        // Admins and staff can create or update subjects
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) && 
                         isValidSubject(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) && 
                         isValidSubject(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;
        
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId);
      }

      // ---- CLASS ROOMS ----
      match /rooms/{roomId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        allow create, update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) &&
                                 request.resource.data.organizationId == organizationId;
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId);
      }

      // ---- CLASS SESSIONS ----
      match /class_sessions/{sessionId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        allow create, update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) &&
                                 isValidClassSession(request.resource.data) &&
                                 request.resource.data.organizationId == organizationId;
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId);
      }

      // ---- ATTENDANCE RECORDS ----
      match /attendance/{attendanceId} {
        // Admins and staff can read all; teachers can only read attendance of subjects they teach
        allow read: if isSuperAdmin() || 
                       isOrganizationAdmin(organizationId) || 
                       isStaff(organizationId) ||
                       (isTeacher(organizationId) && (resource.data.teacherId == getTeacherId() || resource.data.teacherId == request.auth.uid || getTeacherId() == ''));
        
        // Admins, staff or the assigned teacher can create attendance
        allow create: if (isSuperAdmin() || 
                          isOrganizationAdmin(organizationId) || 
                          isStaff(organizationId) ||
                          (isTeacher(organizationId) && (request.resource.data.teacherId == getTeacherId() || request.resource.data.teacherId == request.auth.uid || getTeacherId() == ''))) &&
                         isValidAttendance(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        // Admins, staff or the assigned teacher can update attendance
        allow update: if (isSuperAdmin() || 
                          isOrganizationAdmin(organizationId) || 
                          isStaff(organizationId) ||
                          (isTeacher(organizationId) && 
                           (resource.data.teacherId == getTeacherId() || resource.data.teacherId == request.auth.uid || getTeacherId() == '') && 
                           (request.resource.data.teacherId == getTeacherId() || request.resource.data.teacherId == request.auth.uid || getTeacherId() == ''))) &&
                         isValidAttendance(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;
        
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId);
      }

      // ---- TUITION FEES ----
      match /fees/{feeId} {
        // Public can GET a single paid fee doc by its ID (for receipt verification short links)
        // List is still restricted to authorized staff only
        allow get: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId) ||
                      (resource.data.status == 'paid' || resource.data.status == 'cancelled' || resource.data.status == 'approved');
        allow list: if true; // Allow public to query student debts for verification warning
        
        // Admins and staff can create or update fee invoices
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) && 
                         isValidFee(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isStaff(organizationId)) && 
                         isValidFee(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;
        
        // Permanent financial ledger deletions are restricted to Super Admin or Organization Admin
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- SALARIES ----
      match /salary/{salaryId} {
        // Admins can read all; Teachers can only read their own salaries
        allow read: if isSuperAdmin() || 
                       isOrganizationAdmin(organizationId) || 
                       (isTeacher(organizationId) && (resource.data.teacherId == getTeacherId() || resource.data.teacherId == request.auth.uid || getTeacherId() == ''));
        
        // Only Admins can write salary invoices
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId)) && 
                         isValidSalary(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId)) && 
                         isValidSalary(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;
        
        // Permanent deletions restricted to Super Admin or Organization Admin
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- EXAM SESSIONS ----
      match /exam_sessions/{sessionId} {
        // Staff of the organization can read scheduled exams
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        
        // Admins, staff or Teachers can schedule exams
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || isStaff(organizationId)) && 
                         isValidExam(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || isStaff(organizationId)) && 
                         isValidExam(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;
                         
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || isStaff(organizationId);
      }

      // ---- EXAM RESULTS ----
      match /exam_results/{resultId} {
        // Staff can read if Super Admin, Org Admin, staff or Teacher. Unauthenticated gets allowed if published.
        allow get: if isSuperAdmin() || 
                      isOrganizationAdmin(organizationId) || 
                      isStaff(organizationId) ||
                      resource.data.published == true || 
                      (isTeacher(organizationId) && 
                       exists(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(resource.data.subjectId)) && (
                       get(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(resource.data.subjectId)).data.teacherId == getTeacherId() ||
                       get(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(resource.data.subjectId)).data.teacherId == request.auth.uid ||
                       getTeacherId() == ''
                       ));
        
        // Org members can list results. Unauthenticated users can list published results.
        allow list: if isSuperAdmin() || 
                       isOrganizationAdmin(organizationId) || 
                       isStaff(organizationId) ||
                       isTeacher(organizationId) || 
                       (request.auth == null && resource.data.published == true);

        // Create results: Must be Admin, staff or the assigned Teacher of the subject
        allow create: if (isSuperAdmin() || 
                          isOrganizationAdmin(organizationId) || 
                          isStaff(organizationId) ||
                          (isTeacher(organizationId) && 
                           exists(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(request.resource.data.subjectId)) &&
                           get(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(request.resource.data.subjectId)).data.teacherId == getUserData().teacherId)) &&
                         isValidExamResult(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        // Update results: Must be Admin, staff or the assigned Teacher of the subject
        allow update: if (isSuperAdmin() || 
                          isOrganizationAdmin(organizationId) || 
                          isStaff(organizationId) ||
                          (isTeacher(organizationId) && 
                           exists(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(resource.data.subjectId)) &&
                           get(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(resource.data.subjectId)).data.teacherId == getUserData().teacherId &&
                           exists(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(request.resource.data.subjectId)) &&
                           get(/databases/$(database)/documents/organizations/$(organizationId)/subjects/$(request.resource.data.subjectId)).data.teacherId == getUserData().teacherId)) &&
                         isValidExamResult(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || isStaff(organizationId);
      }

      // ---- SETTINGS ----
      match /settings/{settingId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        allow write: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }
    }
  }
}
