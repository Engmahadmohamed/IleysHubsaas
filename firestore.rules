rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // Global Safety Net & Default Deny
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Core Helper Functions
    // ---------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function userProfileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'oCETlElgWMNrn8ZsSELl1Vsdr0B2' ||
        ('email' in request.auth.token && request.auth.token.email in ['mahadmohamed@gmail.com', 'mahadmohamedone@gmail.com', 'alimahad402@gmail.com']) ||
        (userProfileExists() && getUserData().role == 'superadmin')
      );
    }

    function belongsToOrganization(orgId) {
      return isSignedIn() &&
             userProfileExists() &&
             getUserData().active == true &&
             getUserData().organizationId == orgId;
    }

    function isOrganizationAdmin(orgId) {
      return belongsToOrganization(orgId) &&
             (getUserData().role == 'schooladmin' || getUserData().role == 'quranadmin');
    }

    function isTeacher(orgId) {
      return belongsToOrganization(orgId) && getUserData().role == 'teacher';
    }

    function getTeacherId() {
      return 'teacherId' in getUserData() ? getUserData().teacherId : '';
    }

    function isStaff(orgId) {
      return belongsToOrganization(orgId) && getUserData().role == 'schoolstaff';
    }

    function hasPermission(orgId, permKey) {
      return isSignedIn() &&
             userProfileExists() &&
             getUserData().active == true &&
             getUserData().organizationId == orgId &&
             getUserData().role == 'schoolstaff' &&
             'permissions' in getUserData() &&
             getUserData().permissions.hasAll([permKey]);
    }

    // ---------------------------------------------------------
    // Validation Blueprints
    // ---------------------------------------------------------

    function isValidUserProfile(data) {
      return data.uid is string &&
             data.email is string &&
             data.fullName is string &&
             data.role in ['superadmin', 'schooladmin', 'quranadmin', 'teacher', 'schoolstaff'] &&
             data.organizationId is string &&
             data.active is bool &&
             data.createdAt is string &&
             (!('teacherId' in data) || data.teacherId is string || data.teacherId == null) &&
             (!('staffDesignation' in data) || data.staffDesignation is string || data.staffDesignation == null);
    }

    function isValidOrganization(data) {
      return data.id is string &&
             data.name is string &&
             data.ownerName is string &&
             data.email is string &&
             data.type in ['school', 'quran', 'both'] &&
             data.status in ['active', 'suspended', 'expired'] &&
             data.monthlySubscription is number && data.monthlySubscription >= 0 &&
             data.createdAt is string &&
             (!('logoUrl' in data) || data.logoUrl is string || data.logoUrl == null);
    }

    function isValidStudent(data) {
      return data.id is string &&
             data.studentId is string &&
             data.fullName is string &&
             data.gender in ['male', 'female'] &&
             data.fee is number && data.fee >= 0 &&
             data.organizationId is string &&
             data.createdAt is string &&
             (!('profilePhoto' in data) || data.profilePhoto is string || data.profilePhoto == null) &&
             (!('studentPhone' in data) || data.studentPhone is string || data.studentPhone == null) &&
             (!('parentPhone' in data) || data.parentPhone is string || data.parentPhone == null) &&
             (!('address' in data) || data.address is string || data.address == null) &&
             (!('dob' in data) || data.dob is string || data.dob == null) &&
             (!('subjects' in data) || data.subjects is list || data.subjects == null);
    }

    function isValidTeacher(data) {
      return data.id is string &&
             data.fullName is string &&
             data.email is string &&
             data.salary is number && data.salary >= 0 &&
             data.organizationId is string &&
             data.createdAt is string &&
             (!('profilePhoto' in data) || data.profilePhoto is string || data.profilePhoto == null) &&
             (!('phone' in data) || data.phone is string || data.phone == null) &&
             (!('subjects' in data) || data.subjects is list || data.subjects == null) &&
             (!('rooms' in data) || data.rooms is list || data.rooms == null) &&
             (!('timeSchedule' in data) || data.timeSchedule is list || data.timeSchedule == null);
    }

    function isValidSubject(data) {
      return data.id is string &&
             data.name is string &&
             data.teacherId is string &&
             data.roomId is string &&
             data.organizationId is string &&
             (!('startTime' in data) || data.startTime is string || data.startTime == null) &&
             (!('endTime' in data) || data.endTime is string || data.endTime == null) &&
             (!('capacity' in data) || (data.capacity is number && data.capacity >= 0) || data.capacity == null) &&
             (!('days' in data) || data.days is list || data.days == null);
    }

    function isValidAttendance(data) {
      return data.id is string &&
             data.date is string &&
             data.roomId is string &&
             data.subjectId is string &&
             data.teacherId is string &&
             data.organizationId is string &&
             data.records is list &&
             data.createdAt is string &&
             (!('sessionId' in data) || data.sessionId is string || data.sessionId == null);
    }

    function isValidFee(data) {
      return data.id is string &&
             data.studentId is string &&
             data.studentName is string &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'unpaid', 'paid', 'cancelled'] &&
             data.invoiceNumber is string &&
             data.month is string &&
             data.organizationId is string &&
             (!('paidAt' in data) || data.paidAt is string || data.paidAt == null);
    }

    function isValidSalary(data) {
      return data.id is string &&
             data.teacherId is string &&
             data.teacherName is string &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'paid'] &&
             data.month is string &&
             data.organizationId is string &&
             (!('paidAt' in data) || data.paidAt is string || data.paidAt == null);
    }

    function isValidExam(data) {
      return data.id is string &&
             data.title is string &&
             data.type in ['school', 'class'] &&
             data.createdAt is string &&
             data.published is bool &&
             data.organizationId is string &&
             (!('subjectId' in data) || data.subjectId is string || data.subjectId == null) &&
             (!('targetClass' in data) || data.targetClass is string || data.targetClass == null);
    }

    function isValidExamResult(data) {
      return data.id is string &&
             data.examId is string &&
             data.examTitle is string &&
             data.organizationId is string &&
             data.results is list &&
             data.average is number &&
             data.published is bool &&
             data.createdAt is string &&
             (!('subjectId' in data) || data.subjectId is string || data.subjectId == null);
    }

    function isValidClassSession(data) {
      return data.id is string &&
             data.classCode is string &&
             data.subjectId is string &&
             data.teacherId is string &&
             data.roomId is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.days is list &&
             data.capacity is number && data.capacity >= 0 &&
             data.status in ['active', 'completed'] &&
             data.studentsCount is number &&
             data.organizationId is string &&
             data.createdAt is string;
    }

    // ---------------------------------------------------------
    // Collection Group Security (Zero-Trust Point Queries)
    // ---------------------------------------------------------

    // Students collection group — allow authenticated users + fee-portal public queries
    match /{path=**}/students/{studentId} {
      allow list: if isSuperAdmin() ||
                     request.auth != null ||
                     (request.auth == null && request.query.limit <= 1);
      allow get: if isSuperAdmin() || request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Class Sessions collection group
    match /{path=**}/class_sessions/{sessionId} {
      allow list, get: if isSuperAdmin() || request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Teachers collection group
    match /{path=**}/teachers/{teacherId} {
      allow list, get: if isSuperAdmin() || request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ---------------------------------------------------------
    // 1. Users Collection
    // ---------------------------------------------------------
    match /users/{userId} {
      // Users can always read their own profile; org members can read others in same org
      allow get: if isSignedIn() && (
                    isSuperAdmin() ||
                    request.auth.uid == userId ||
                    (userProfileExists() && getUserData().organizationId != null)
                  );

      // List all users: admins and teachers (filtered by organizationId in app code)
      allow list: if isSignedIn() && (
                     isSuperAdmin() ||
                     (userProfileExists() && (getUserData().role == 'schooladmin' || getUserData().role == 'quranadmin' || getUserData().role == 'teacher' || getUserData().role == 'schoolstaff'))
                  );

      allow create: if isSuperAdmin() ||
                       (isOrganizationAdmin(request.resource.data.organizationId) &&
                        isValidUserProfile(request.resource.data) &&
                        request.resource.data.role in ['schooladmin', 'quranadmin', 'teacher', 'schoolstaff']);

      allow update: if (isSuperAdmin() && isValidUserProfile(request.resource.data)) ||
                      (isSignedIn() && request.auth.uid == userId &&
                       isValidUserProfile(request.resource.data) &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.organizationId == resource.data.organizationId &&
                       request.resource.data.active == resource.data.active) ||
                      (isOrganizationAdmin(resource.data.organizationId) &&
                       isValidUserProfile(request.resource.data) &&
                       request.resource.data.organizationId == resource.data.organizationId &&
                       request.resource.data.role in ['schooladmin', 'quranadmin', 'teacher', 'schoolstaff'] &&
                       resource.data.role != 'superadmin');

      allow delete: if isSuperAdmin() ||
                       (isOrganizationAdmin(resource.data.organizationId) &&
                        resource.data.role in ['teacher', 'schoolstaff'] &&
                        resource.data.organizationId == getUserData().organizationId);
    }

    // ---------------------------------------------------------
    // 2. Multi-Tenant Scoped Collections
    // ---------------------------------------------------------
    match /organizations/{organizationId} {

      // Only authenticated org members or superadmin can read org details;
      // public portals may read org name for display via direct doc get.
      allow get: if isSuperAdmin() || belongsToOrganization(organizationId) || (request.auth == null && resource.data.name is string);
      allow list: if isSuperAdmin() || (isSignedIn() && userProfileExists());
      allow write: if isSuperAdmin() && (request.resource == null || isValidOrganization(request.resource.data));

      // ---- COUNTERS (auto-increment IDs) ----
      match /counters/{counterId} {
        allow read, write: if isSuperAdmin() ||
                              isOrganizationAdmin(organizationId) ||
                              hasPermission(organizationId, 'Students');
      }

      // ---- STUDENTS ----
      match /students/{studentId} {
        allow get: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       isTeacher(organizationId) ||
                       hasPermission(organizationId, 'Students') ||
                       (request.auth == null && resource.data.studentId is string); // public fee/result portal

        allow list: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       isTeacher(organizationId) ||
                       hasPermission(organizationId, 'Students') ||
                       (request.auth == null && request.query.limit <= 1); // public result/fee portal search

        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Students')) &&
                         isValidStudent(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Students')) &&
                         isValidStudent(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- TEACHERS ----
      match /teachers/{teacherId} {
        allow read: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       hasPermission(organizationId, 'Teachers') ||
                       belongsToOrganization(organizationId);

        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Teachers')) &&
                         isValidTeacher(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Teachers')) &&
                         isValidTeacher(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Teachers');
      }

      // ---- SUBJECTS ----
      match /subjects/{subjectId} {
        allow read: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       hasPermission(organizationId, 'Subjects') ||
                       belongsToOrganization(organizationId) ||
                       request.auth == null; // Allow public portal to read subject names

        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Subjects')) &&
                         isValidSubject(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Subjects')) &&
                         isValidSubject(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Subjects');
      }

      // ---- CLASS ROOMS ----
      match /rooms/{roomId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        allow create, update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Class Rooms')) &&
                                 request.resource.data.organizationId == organizationId;
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Class Rooms');
      }

      // ---- CLASS SESSIONS ----
      match /class_sessions/{sessionId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Class Sessions')) &&
                         isValidClassSession(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;
        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Class Sessions')) &&
                         isValidClassSession(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;
        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Class Sessions');
      }

      // ---- ATTENDANCE ----
      // Teachers can create and update attendance for their organization.
      // Admin can read all attendance records.
      match /attendance/{attendanceId} {
        allow read: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       hasPermission(organizationId, 'Attendance') ||
                       isTeacher(organizationId);

        // Any teacher in the org can create a new attendance record
        allow create: if (isSuperAdmin() ||
                          isOrganizationAdmin(organizationId) ||
                          hasPermission(organizationId, 'Attendance') ||
                          isTeacher(organizationId)) &&
                         isValidAttendance(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        // Any teacher or admin in the org can update (handles "re-save" same day scenario)
        allow update: if (isSuperAdmin() ||
                          isOrganizationAdmin(organizationId) ||
                          hasPermission(organizationId, 'Attendance') ||
                          isTeacher(organizationId)) &&
                         isValidAttendance(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Attendance');
      }

      // ---- TUITION FEES ----
      match /fees/{feeId} {
        // Authenticated staff can read all fees; public can read a SINGLE fee doc for receipt verification only
        allow get: if isSuperAdmin() ||
                      isOrganizationAdmin(organizationId) ||
                      hasPermission(organizationId, 'Fees') ||
                      (request.auth == null && resource.data.invoiceNumber is string); // receipt check only

        // List: org members + fee portal / receipt debt lookup (unauthenticated, by studentId)
        allow list: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       hasPermission(organizationId, 'Fees') ||
                       (request.auth == null && request.query.limit <= 50); // fee portal by studentId

        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Fees')) &&
                         isValidFee(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Fees')) &&
                         isValidFee(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- SALARIES ----
      match /salary/{salaryId} {
        allow get: if isSuperAdmin() ||
                      isOrganizationAdmin(organizationId) ||
                      hasPermission(organizationId, 'Teacher Salary') ||
                      (isTeacher(organizationId) && (resource.data.teacherId == getTeacherId() || resource.data.teacherId == request.auth.uid || getTeacherId() == ''));
        
        allow list: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       hasPermission(organizationId, 'Teacher Salary') ||
                       isTeacher(organizationId);

        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Teacher Salary')) &&
                         isValidSalary(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Teacher Salary')) &&
                         isValidSalary(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Teacher Salary');
      }

      // ---- EXAM SESSIONS ----
      match /exam_sessions/{sessionId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);

        allow create: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || hasPermission(organizationId, 'Exams')) &&
                         isValidExam(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || hasPermission(organizationId, 'Exams')) &&
                         isValidExam(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || hasPermission(organizationId, 'Exams');
      }

      // ---- EXAM RESULTS ----
      match /exam_results/{resultId} {
        allow get: if isSuperAdmin() ||
                      isOrganizationAdmin(organizationId) ||
                      hasPermission(organizationId, 'Exams') ||
                      resource.data.published == true ||
                      isTeacher(organizationId);

        allow list: if isSuperAdmin() ||
                       isOrganizationAdmin(organizationId) ||
                       hasPermission(organizationId, 'Exams') ||
                       isTeacher(organizationId) ||
                       request.auth == null; // public results portal (only published results are shown)

        allow create: if (isSuperAdmin() ||
                          isOrganizationAdmin(organizationId) ||
                          hasPermission(organizationId, 'Exams') ||
                          isTeacher(organizationId)) &&
                         isValidExamResult(request.resource.data) &&
                         request.resource.data.organizationId == organizationId;

        allow update: if (isSuperAdmin() ||
                          isOrganizationAdmin(organizationId) ||
                          hasPermission(organizationId, 'Exams') ||
                          isTeacher(organizationId)) &&
                         isValidExamResult(request.resource.data) &&
                         request.resource.data.organizationId == resource.data.organizationId &&
                         request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isSuperAdmin() || isOrganizationAdmin(organizationId) || isTeacher(organizationId) || hasPermission(organizationId, 'Exams');
      }

      // ---- REPORTS ----
      match /reports/{reportId} {
        allow read: if isSuperAdmin() || isOrganizationAdmin(organizationId) || hasPermission(organizationId, 'Print Reports');
        allow write: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }

      // ---- SETTINGS ----
      match /settings/{settingId} {
        allow read: if isSuperAdmin() || belongsToOrganization(organizationId);
        allow write: if isSuperAdmin() || isOrganizationAdmin(organizationId);
      }
    }
  }
}
